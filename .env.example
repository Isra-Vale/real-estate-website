# Copy this file to `.env` and set your real API's base URL.
#
# When this is unset (or the .env file doesn't exist), the app uses the
# built-in mock data automatically — nothing else to configure.
#
# When it IS set, every page tries the real API first:
#   GET {VITE_API_BASE_URL}/properties
#   GET {VITE_API_BASE_URL}/properties/:id
#   GET {VITE_API_BASE_URL}/agents
#   GET {VITE_API_BASE_URL}/testimonials
#   GET {VITE_API_BASE_URL}/stats
#   GET {VITE_API_BASE_URL}/posts
#   GET {VITE_API_BASE_URL}/posts/:id
#   GET {VITE_API_BASE_URL}/rentals
#
# If any of those requests fails (network error, non-2xx status, or takes
# longer than 5 seconds), that specific page silently falls back to mock
# data — the rest of the site keeps working normally either way.
#
# See src/services/api.js for the exact fallback logic, and
# src/data/mockData.js for the shape each endpoint is expected to return.

VITE_API_BASE_URL=https://api.example.com
